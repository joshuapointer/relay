{
  "name": "@relay/ui-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@relay/design-tokens": "workspace:*",
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "react": "^18"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@relay/config-eslint": "workspace:*",
    "@relay/config-tsconfig": "workspace:*",
    "@relay/config-vitest": "workspace:*",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18",
    "jsdom": "^24.0.0",
    "react": "^18.3.1",
    "react-native": "^0.74.0",
    "typescript": "^5.4",
    "vitest": "^2.1.9"
  }
}
