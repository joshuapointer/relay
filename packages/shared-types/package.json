{
  "name": "@relay/shared-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./status": {
      "types": "./dist/status.d.ts",
      "import": "./dist/status.js"
    },
    "./shipment": {
      "types": "./dist/shipment.d.ts",
      "import": "./dist/shipment.js"
    },
    "./notification": {
      "types": "./dist/notification.d.ts",
      "import": "./dist/notification.js"
    },
    "./share": {
      "types": "./dist/share.d.ts",
      "import": "./dist/share.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3"
  },
  "devDependencies": {
    "@relay/config-eslint": "workspace:*",
    "@relay/config-tsconfig": "workspace:*",
    "@relay/config-vitest": "workspace:*",
    "@vitest/coverage-v8": "^2",
    "typescript": "^5.4",
    "vitest": "^2"
  }
}
