# ============================================================
# Relay — Master Environment Template
# ============================================================
# Copy this file to .env (never commit .env with real values).
# Variables marked [REQUIRED prod] must be set before deploying.
# Variables marked [MOCK OK] can be omitted in mock mode.
#
# Mock mode: set CLERK_MOCK_MODE=true + EASYPOST_MOCK_MODE=true
# to run the full stack with zero external accounts.
# ============================================================

# ── API ──────────────────────────────────────────────────────
# Server port (default: 4000)
PORT=4000

# Node environment: development | test | production
NODE_ENV=development

# Allowed CORS origin for the web app
CORS_ORIGIN=http://localhost:3000

# Base URL used when generating public share links
PUBLIC_BASE_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
# [REQUIRED prod] PostgreSQL connection string
# Local dev: use docker-compose (postgres service) or a local Postgres instance
# Production: use Neon (https://neon.tech) or Fly Postgres
DATABASE_URL=postgresql://relay:relay_dev_password@localhost:5432/relay_dev

# ── Web ──────────────────────────────────────────────────────
# API base URL for the Next.js frontend
NEXT_PUBLIC_API_URL=http://localhost:4000

# WebSocket URL for real-time updates
NEXT_PUBLIC_WS_URL=http://localhost:4000

# ── Mobile ───────────────────────────────────────────────────
# API base URL for the Expo mobile app
EXPO_PUBLIC_API_URL=http://localhost:4000

# WebSocket URL for real-time updates (mobile)
EXPO_PUBLIC_WS_URL=ws://localhost:4000

# ── Clerk (Auth) ─────────────────────────────────────────────
# [MOCK OK] Set CLERK_MOCK_MODE=true to skip all Clerk calls
# Get real keys from: https://dashboard.clerk.com

# Backend secret key — used by API to verify JWTs
# [REQUIRED prod]
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Publishable key — used by Web and Mobile clients
# [REQUIRED prod]
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# JWKS endpoint — API fetches public keys for JWT verification
# [REQUIRED prod]
CLERK_JWKS_URL=https://clerk.yourdomain.com/.well-known/jwks.json

# Issuer URL (matches iss claim in Clerk JWTs)
# [REQUIRED prod]
CLERK_ISSUER=https://clerk.yourdomain.com

# Enable mock auth — auto-signs in a test user with no real Clerk calls
# Default: true (safe for local dev). NEVER set true in production.
CLERK_MOCK_MODE=true
NEXT_PUBLIC_CLERK_MOCK_MODE=true

# ── EasyPost (Shipping) ──────────────────────────────────────
# [MOCK OK] Set EASYPOST_MOCK_MODE=true to use MSW stubs
# Get real keys from: https://www.easypost.com/account/api-keys

# EasyPost API key for creating and tracking shipments
# [REQUIRED prod]
EASYPOST_API_KEY=EZT_your_easypost_api_key

# Webhook HMAC secret for verifying EasyPost webhook payloads
# [REQUIRED prod]
EASYPOST_WEBHOOK_SECRET=your-webhook-secret

# Enable mock EasyPost — uses MSW stubs, no real API calls
# Default: true for local dev and test. NEVER set true in production.
EASYPOST_MOCK_MODE=true

# ── Observability ────────────────────────────────────────────
# [MOCK OK] Can be omitted in development

# Sentry DSN for error tracking
# Get from: https://sentry.io
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Expo push notification access token
# Get from: https://expo.dev/accounts/[account]/settings/access-tokens
EXPO_ACCESS_TOKEN=your-expo-access-token

# Redis connection string for Socket.IO pub/sub adapter
# Local dev: redis://localhost:6379 (docker-compose redis service)
# Production: use Upstash (https://upstash.com)
SOCKET_IO_REDIS_URL=redis://localhost:6379
