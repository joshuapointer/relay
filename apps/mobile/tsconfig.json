{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@relay/config-tsconfig/react-native.json",
  "compilerOptions": {
    "types": ["jest", "node"],
    "paths": {
      "@/*": ["./*"],
      "@relay/design-tokens": [
        "../../packages/design-tokens/src/index.ts"
      ],
      "@relay/design-tokens/native": [
        "../../packages/design-tokens/src/native.ts"
      ],
      "@relay/shared-types": [
        "../../packages/shared-types/src/index.ts"
      ],
      "@relay/sdk": [
        "../../packages/sdk/src/index.ts"
      ],
      "@relay/ui-core": [
        "../../packages/ui-core/src/index.ts"
      ]
    }
  },
  "include": [
    "app/**/*",
    "components/**/*",
    "hooks/**/*",
    "src/**/*",
    "__tests__/**/*",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js"
  ],
  "exclude": ["node_modules", "dist"]
}
