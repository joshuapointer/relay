{
  "framework": "nextjs",
  "buildCommand": "pnpm -w turbo run build --filter=@relay/web",
  "outputDirectory": "apps/web/.next",
  "installCommand": "pnpm install --frozen-lockfile",
  "env": {
    "AUTHENTIK_ISSUER": "@relay-authentik-issuer",
    "AUTHENTIK_CLIENT_ID": "@relay-authentik-client-id",
    "AUTHENTIK_CLIENT_SECRET": "@relay-authentik-client-secret",
    "NEXTAUTH_URL": "@relay-nextauth-url",
    "NEXTAUTH_SECRET": "@relay-nextauth-secret",
    "NEXT_PUBLIC_API_URL": "@relay-api-url",
    "NEXT_PUBLIC_WS_URL": "@relay-ws-url"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
