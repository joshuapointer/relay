{
  "framework": "nextjs",
  "buildCommand": "pnpm -w turbo run build --filter=@relay/web",
  "outputDirectory": "apps/web/.next",
  "installCommand": "pnpm install --frozen-lockfile",
  "env": {
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY": "@relay-clerk-publishable-key",
    "CLERK_SECRET_KEY": "@relay-clerk-secret-key",
    "NEXT_PUBLIC_API_URL": "@relay-api-url",
    "NEXT_PUBLIC_WS_URL": "@relay-ws-url",
    "NEXT_PUBLIC_CLERK_MOCK_MODE": "false"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
